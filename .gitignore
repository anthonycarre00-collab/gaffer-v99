vitest-*.json

# World JSON exports (large files, generated locally)
exported_world.json
test-world.json

# Personal-use imported world assets/data
/public/assets/worlds/

# Built OFM packages (generated locally; saving here during tauri dev would
# trigger the file watcher and restart the app)
/src-tauri/data/*.ofm
/src-tauri/databases/*.ofm

# Mobile icon folders — this is a desktop-only Tauri app. `tauri icon`
# regenerates iOS/Android icons by default; ignore them so they don't get
# committed. The desktop icons (32x32, 128x128, icon.icns, icon.ico, Square*.png,
# StoreLogo.png) are tracked manually above.
/src-tauri/icons/ios/
/src-tauri/icons/android/
